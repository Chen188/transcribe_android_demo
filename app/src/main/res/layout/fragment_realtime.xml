<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:elevation="2dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/realtime_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/realtime_subtitle"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Controls card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:elevation="2dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_audio_source"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/spinnerSource"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/rounded_result_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPreview"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/btn_preview"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp" />

        <!-- Language mode -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_language_mode"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerLanguageMode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/rounded_result_box"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="4dp" />

        <!-- Manual language picker -->
        <LinearLayout
            android:id="@+id/layoutManualLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_language"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/rounded_result_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

        <!-- Candidate language selector (visible in Multi-language mode) -->
        <LinearLayout
            android:id="@+id/layoutCandidateLanguages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_candidate_languages"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtSelectLanguages"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/rounded_result_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:text="@string/btn_select_languages"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:drawableEnd="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Speaker identification -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSpeakerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_speaker_id"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartStreaming"
            android:layout_width="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_height="48dp"
            android:text="@string/btn_start_streaming"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_realtime"
            app:iconGravity="textStart" />

    </LinearLayout>

    <!-- Result card (fills remaining space) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:elevation="2dp"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_transcription_output"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:id="@+id/scrollStreaming"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rounded_result_box"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtStreamingResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary" />
        </ScrollView>

    </LinearLayout>

</LinearLayout>
