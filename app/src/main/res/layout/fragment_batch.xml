<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="2dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/batch_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/batch_subtitle"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Upload card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="2dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_s3_upload"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Pre-upload controls -->
            <LinearLayout
                android:id="@+id/layoutUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Spinner
                        android:id="@+id/spinnerBucket"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_result_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefresh"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_refresh"
                        android:textAllCaps="false"
                        app:cornerRadius="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_test_file"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Spinner
                        android:id="@+id/spinnerTestFile"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_result_box"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/btn_preview"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpload"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_upload_s3"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <!-- Post-upload success display -->
            <LinearLayout
                android:id="@+id/layoutUploaded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_success_box"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtS3Uri"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_reset"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

        </LinearLayout>

        <!-- Job config card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="2dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_job_config"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <!-- Language mode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_language_mode"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerLanguageMode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/rounded_result_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtLanguageModeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/language_mode_hint"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Manual language picker (visible in Manual mode) -->
            <LinearLayout
                android:id="@+id/layoutManualLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_language"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_result_box"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

            <!-- Candidate language selector (visible in Auto-detect / Multi-language modes) -->
            <LinearLayout
                android:id="@+id/layoutCandidateLanguages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_candidate_languages"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txtSelectLanguages"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_result_box"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical"
                    android:text="@string/btn_select_languages"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:drawableEnd="@android:drawable/arrow_down_float" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Speaker identification -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchSpeakerId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_speaker_id"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/layoutMaxSpeakers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_max_speakers"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <Spinner
                    android:id="@+id/spinnerMaxSpeakers"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_result_box"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="16dp" />

            <!-- Output bucket -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_output"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerOutput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/rounded_result_box"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Job name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_job_name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtJobName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Actions card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="2dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartBatch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_start_job"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_batch"
                app:iconGravity="textStart"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheckStatus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_check_status"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnListJobs"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_list_jobs"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Result card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="2dp"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_result"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtBatchResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_result_box"
                android:minHeight="120dp"
                android:padding="12dp"
                android:text=""
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
